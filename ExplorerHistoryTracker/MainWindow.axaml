<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ExplorerHistoryTracker.ViewModels"
        xmlns:models="using:ExplorerHistoryTracker.Models"
        xmlns:converters="using:ExplorerHistoryTracker.Converters"
        mc:Ignorable="d" d:DesignWidth="380" d:DesignHeight="550"
        x:Class="ExplorerHistoryTracker.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Tuna" 
        Icon="/Tuna.ico"
        Width="380" Height="550"
        SystemDecorations="None" 
        Background="Transparent"
        WindowStartupLocation="Manual"
        CanResize="True"
        ShowInTaskbar="False"
        Foreground="{DynamicResource TextPrimaryBrush}"
        Topmost="{Binding IsTopmost, Mode=TwoWay}">

    <Window.Resources>
        <!-- Import converters -->
        <converters:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
        <converters:StringEqualsToBooleanConverter x:Key="StringToBoolConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Global ToolTip Style -->
        <Style Selector="ToolTip">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Segmented Tab RadioButton Style (Pill shape) -->
        <Style Selector="RadioButton.tab">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Margin="2,0">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.tab:checked /template/ Border#border">
            <Setter Property="Background" Value="{DynamicResource TabCheckedBgBrush}"/>
            <Setter Property="BoxShadow" Value="0 2 6 0 #15000000"/>
        </Style>
        <Style Selector="RadioButton.tab:checked">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="RadioButton.tab:pointerover">
            <Setter Property="Background" Value="{DynamicResource TabHoverBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <!-- Compact standalone category tags -->
        <Style Selector="ToggleButton.filter-tag">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="54"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.filter-tag:checked">
            <Setter Property="Background" Value="{DynamicResource TabCheckedBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="ToggleButton.filter-tag:pointerover">
            <Setter Property="Background" Value="{DynamicResource TabHoverBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <!-- Custom Search TextBox Style -->
        <Style Selector="TextBox.search">
            <Setter Property="Background" Value="{DynamicResource SearchBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="6,6,32,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TextBox.search:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchBgBrush}"/>
        </Style>

        <!-- Custom ListBoxItem Style (Clean card container wrapper) -->
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Outer Card Hover/Selected Feedback -->
        <Style Selector="ListBoxItem:pointerover Border.outer-card">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.outer-card">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SelectedBgBrush}"/>
        </Style>

        <!-- Compact action buttons for item headers -->
        <Style Selector="Button.circle-action">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="ActionSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.circle-action Path">
            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.circle-action:pointerover /template/ Border#ActionSurface">
            <Setter Property="Background" Value="{DynamicResource ActionHoverBgBrush}"/>
        </Style>
        <Style Selector="Button.circle-action:pointerover Path">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
        </Style>
        
        <!-- Pinned state remains visible without changing the button geometry -->
        <Style Selector="Button.circle-action.pinned">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.circle-action.pinned Path">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <!-- Delete uses the same rectangle interaction with a danger color -->
        <Style Selector="Button.circle-action.danger:pointerover /template/ Border#ActionSurface">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBgBrush}"/>
        </Style>
        <Style Selector="Button.circle-action.danger:pointerover Path">
            <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
        </Style>
        <Style Selector="Button.circle-action.danger">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Muted Section Subheaders Style -->
        <Style Selector="TextBlock.subheader">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="0.8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Title Bar Close Button Style -->
        <Style Selector="Button.title-close">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.title-close Path">
            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Fill" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.title-close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E81123"/>
        </Style>
        <Style Selector="Button.title-close:pointerover Path">
            <Setter Property="Fill" Value="#FFFFFF"/>
        </Style>

        <!-- Pin Toggle Button Style -->
        <Style Selector="ToggleButton.pin">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PinSurface" Background="Transparent" CornerRadius="6">
                        <ContentPresenter Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.pin:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ActionHoverBgBrush}"/>
        </Style>
        <Style Selector="ToggleButton.pin Path">
            <Setter Property="Data" Value="M16 9V4h1c.55 0 1-.45 1-1s-.45-1-1-1H7c-.55 0-1 .45-1 1s.45 1 1 1h1v5c0 1.66-1.34 3-3 3v2h5.97v7l1 1 1-1v-7H19v-2c-1.66 0-3-1.34-3-3z"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Stroke" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <RotateTransform Angle="45"/>
                        <TranslateTransform Y="1.2"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Fill" Duration="0:0:0.1"/>
                    <BrushTransition Property="Stroke" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.pin:pointerover Path">
            <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="ToggleButton.pin:checked Path">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.pin:checked:pointerover Path">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Stroke" Value="Transparent"/>
        </Style>
        <!-- Use the same two-state pin geometry as the history list actions. -->
        <Style Selector="ToggleButton.pin:pointerover /template/ Border#PinSurface">
            <Setter Property="Background" Value="{DynamicResource ActionHoverBgBrush}"/>
        </Style>
        <Style Selector="ToggleButton.pin Path">
            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <RotateTransform Angle="45"/>
                        <TranslateTransform Y="1.3"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.pin:checked Path">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="0.7"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Hover Action Control Toggle (Opacity-based to prevent layout shifts & flutter) -->
        <Style Selector="ListBoxItem StackPanel.actions">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBoxItem StackPanel.time">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBoxItem:pointerover StackPanel.actions">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover StackPanel.time">
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <!-- Circle Action Button Style -->
        <Style Selector="Button.action">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="RenderTransform" Value="scale(1.0)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.action:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.08)"/>
        </Style>
        <Style Selector="Button.action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ActionHoverBgBrush}"/>
        </Style>
        <Style Selector="Button.action Path">
            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Fill" Duration="0:0:0.1"/>
                    <BrushTransition Property="Stroke" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.action:pointerover Path">
            <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.action.pin-btn:pointerover Path">
            <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>



        <!-- ContextMenu Dark Styling -->
        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource ContextMenuBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style Selector="MenuItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource MenuItemHoverBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <!-- Flat Separator inside ContextMenu -->
        <Style Selector="Separator">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="4,4"/>
        </Style>

        <!-- Spin Animation for Refresh Button -->
        <Style Selector="Path.spin">
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Modern Accent Buttons -->
        <Style Selector="Button.modern">
            <Setter Property="Background" Value="{DynamicResource ModernButtonBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ModernButtonFgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style Selector="Button.modern:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <Style Selector="Button.modern:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>
        <Style Selector="Button.outline">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.outline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <Style Selector="Button.danger_outline">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.danger_outline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <!-- ================= SETTINGS PAGE UI OPTIMIZATION (Screenshot Tool Style) ================= -->
        <!-- Win11 Style Card -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="BoxShadow" Value="0 2 12 0 #08000000" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style Selector="TextBlock.cardTitle">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style Selector="Border.fieldRow">
            <Setter Property="MinHeight" Value="38" />
        </Style>

        <Style Selector="TextBlock.fieldLabel">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="TextBlock.fieldHint">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>

        <Style Selector="Border.softDivider">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="0,8" />
        </Style>

        <!-- Segmented Controls Style -->
        <Style Selector="RadioButton.segmented">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" Padding="10,0" CornerRadius="6" MinHeight="26">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="RadioButton.segmented:pointerover /template/ Border">
            <Setter Property="Background" Value="{DynamicResource TabHoverBgBrush}" />
        </Style>

        <Style Selector="RadioButton.segmented:checked /template/ Border">
            <Setter Property="Background" Value="{DynamicResource TabCheckedBgBrush}" />
            <Setter Property="BoxShadow" Value="0 1 4 0 #15000000" />
        </Style>

        <Style Selector="RadioButton.segmented:checked">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Rectangle.segmentedDivider">
            <Setter Property="Width" Value="1" />
            <Setter Property="Fill" Value="{DynamicResource BorderBrush}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,4" />
        </Style>

        <!-- Custom Sleek ScrollBars -->
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ScrollBar:pointerover">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ScrollBar /template/ RepeatButton">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ScrollBar /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ScrollBar:pointerover /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
        </Style>
        <Style Selector="ScrollBar:vertical /template/ Thumb">
            <Setter Property="Background" Value="#33888888"/>
            <Setter Property="Width" Value="4"/>
            <Setter Property="MinWidth" Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ScrollBar:vertical:pointerover">
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
        </Style>
        <Style Selector="ScrollBar:vertical:pointerover /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Width" Value="5"/>
            <Setter Property="MinWidth" Value="5"/>
        </Style>
        <Style Selector="ScrollBar:horizontal">
            <Setter Property="Height" Value="6"/>
            <Setter Property="MinHeight" Value="6"/>
        </Style>
        <Style Selector="ScrollBar:horizontal /template/ Thumb">
            <Setter Property="Background" Value="#33888888"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="MinHeight" Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ScrollBar:horizontal:pointerover">
            <Setter Property="Height" Value="6"/>
            <Setter Property="MinHeight" Value="6"/>
        </Style>
        <Style Selector="ScrollBar:horizontal:pointerover /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Height" Value="5"/>
            <Setter Property="MinHeight" Value="5"/>
        </Style>
    </Window.Styles>

    <!-- Main Container with Shadow and Rounded Corner -->
    <Border CornerRadius="12" 
            Background="{DynamicResource BgPrimaryBrush}" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1" 
            ClipToBounds="True"
            BoxShadow="0 4 18 0 #1F000000">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>   <!-- Custom Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Search & Control -->
                <RowDefinition Height="Auto"/> <!-- Horizontal Tab Switcher -->
                <RowDefinition Height="*"/>    <!-- Active Content Page -->
            </Grid.RowDefinitions>

            <!-- ================= 0. TITLE BAR ================= -->
            <Grid Grid.Row="0" Name="TitleBar" Background="{DynamicResource HeaderBgBrush}" PointerPressed="TitleBar_PointerPressed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <!-- Brand Icon (Tuna Logo) -->
                    <Image Source="/Tuna.png" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Tuna" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <!-- Brand Identifier Badge -->
                    <Border Background="{DynamicResource AccentBrush}" BorderThickness="0" CornerRadius="4" Padding="5,1.5" VerticalAlignment="Center">
                        <TextBlock Text="Quicker·地球村" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource ModernButtonFgBrush}" LetterSpacing="0.5" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                    <!-- Topmost Pin Toggle Button -->
                    <ToggleButton Classes="pin" IsChecked="{Binding IsTopmost, Mode=TwoWay}" ToolTip.Tip="置顶" Margin="0,0,4,0">
                        <Path Width="16" Height="16" Stretch="Uniform"/>
                    </ToggleButton>

                    <!-- Close Button -->
                    <Button Classes="title-close" Click="CloseButton_Click" ToolTip.Tip="关闭并隐藏" Width="28" Height="28">
                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ================= 1. SEARCH & CONTROL BAR ================= -->
            <Grid Grid.Row="1" Margin="12,8,12,8" IsVisible="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Classes="search" Text="{Binding SearchText, Mode=TwoWay}" Watermark="搜索历史文件夹或完整路径...">
                    <TextBox.InnerLeftContent>
                        <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                              Fill="{DynamicResource TextSecondaryBrush}" Width="12" Height="12" Stretch="Uniform" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </TextBox.InnerLeftContent>
                </TextBox>
                
                <!-- Refresh Button -->
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Width="32" Height="32" Margin="8,0,0,0" Background="Transparent" BorderThickness="0" ToolTip.Tip="刷新历史记录" IsEnabled="{Binding IsSyncButtonEnabled}">
                    <Button.Template>
                        <ControlTemplate>
                            <Border x:Name="border" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                                <Path x:Name="path" Classes.spin="{Binding DataContext.IsSyncing, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" 
                                      Fill="{DynamicResource TextSecondaryBrush}" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="50%,50%">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </Path.RenderTransform>
                                </Path>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ================= 2. HORIZONTAL TAB SWITCHER ================= -->
            <Grid Grid.Row="2" Margin="12,0,12,12">
                <Border Background="{DynamicResource BgSecondaryBrush}" BorderThickness="0" CornerRadius="8" Padding="4">
                    <UniformGrid Columns="4">
                        <RadioButton Content="最近" Classes="tab"
                                     IsChecked="{Binding CurrentTab, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Recent, Mode=OneWay}"
                                     Command="{Binding SwitchTabCommand}" CommandParameter="Recent"/>
                        <RadioButton Content="置顶" Classes="tab"
                                     IsChecked="{Binding CurrentTab, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Pinned, Mode=OneWay}"
                                     Command="{Binding SwitchTabCommand}" CommandParameter="Pinned"/>
                        <RadioButton Content="高频" Classes="tab"
                                     IsChecked="{Binding CurrentTab, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Stats, Mode=OneWay}"
                                     Command="{Binding SwitchTabCommand}" CommandParameter="Stats"/>
                        <RadioButton Content="设置" Classes="tab"
                                     IsChecked="{Binding CurrentTab, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Settings, Mode=OneWay}"
                                     Command="{Binding SwitchTabCommand}" CommandParameter="Settings"/>
                    </UniformGrid>
                </Border>
            </Grid>

            <!-- ================= 3. ACTIVE CONTENT PAGE ================= -->
            <Grid Grid.Row="3" Margin="12,0,12,12">

                <!-- ================= 3.1 RECENT LISTS (SPLIT FOLDERS / APPS & FILES) ================= -->
                <Grid IsVisible="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header 1 -->
                        <RowDefinition Height="*"/>    <!-- Folder List -->
                        <RowDefinition Height="Auto"/> <!-- Header 2 -->
                        <RowDefinition Height="*"/>    <!-- App & File List -->
                    </Grid.RowDefinitions>

                    <!-- Header 1: Folders -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                        <TextBlock Text="最近访问的文件夹" Classes="subheader"/>
                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="8,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Folders List wrapped in Border -->
                    <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" BorderThickness="0" BoxShadow="0 2 10 0 #0A000000" CornerRadius="10" Padding="8" Margin="0,0,0,12">
                        <ListBox ItemsSource="{Binding RecentItems}" 
                                 Background="Transparent" BorderThickness="0" Padding="0"
                                 DoubleTapped="HistoryList_DoubleTapped">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:FolderHistoryItem}">
                                    <Border Classes="outer-card" Background="{DynamicResource BgSecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8,6">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="打开文件夹" Command="{Binding $parent[Window].DataContext.OpenFolderCommand}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="复制完整路径" Command="{Binding $parent[Window].DataContext.CopyPathCommand}" CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="置顶 / 取消置顶" Command="{Binding $parent[Window].DataContext.PinFolderCommand}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="删除历史记录" Command="{Binding $parent[Window].DataContext.DeleteFolderCommand}" CommandParameter="{Binding}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid RowDefinitions="Auto,Auto">
                                            <!-- Top Row (Header) -->
                                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                                <!-- Left: App Icon & Name -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <Image Source="{Binding Icon}" Width="12" Height="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding AppName}" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                
                                                <!-- Right: Action Buttons & Time -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <!-- Action Buttons (circular, outline) -->
                                                    <!-- Open Button -->
                                                    <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.OpenFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="打开">
                                                        <Path Data="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" 
                                                              Width="11" Height="11" Stretch="Uniform"/>
                                                    </Button>
                                                    
                                                    <!-- Pin Button (Unpinned State) -->
                                                    <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.PinFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="置顶" IsVisible="{Binding !IsPinned}">
                                                        <Path Data="M16 9V4h1c.55 0 1-.45 1-1s-.45-1-1-1H7c-.55 0-1 .45-1 1s.45 1 1 1h1v5c0 1.66-1.34 3-3 3v2h5.97v7l1 1 1-1v-7H19v-2c-1.66 0-3-1.34-3-3z" 
                                                              Width="11" Height="11" Stretch="Uniform"
                                                              RenderTransformOrigin="50%,50%">
                                                            <Path.RenderTransform>
                                                                <TransformGroup>
                                                                    <RotateTransform Angle="45"/>
                                                                    <TranslateTransform Y="1"/>
                                                                </TransformGroup>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                    </Button>
                                                    
                                                    <!-- Pin Button (Pinned State) -->
                                                    <Button Classes="circle-action pinned" Command="{Binding $parent[Window].DataContext.PinFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="取消置顶" IsVisible="{Binding IsPinned}">
                                                        <Path Data="M16 9V4h1c.55 0 1-.45 1-1s-.45-1-1-1H7c-.55 0-1 .45-1 1s.45 1 1 1h1v5c0 1.66-1.34 3-3 3v2h5.97v7l1 1 1-1v-7H19v-2c-1.66 0-3-1.34-3-3z" 
                                                              Width="11" Height="11" Stretch="Uniform"
                                                              RenderTransformOrigin="50%,50%">
                                                            <Path.RenderTransform>
                                                                <TranslateTransform Y="1"/>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                    </Button>
                                                    
                                                    <!-- Copy Path Button (Tag shape icon) -->
                                                    <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.CopyPathCommand}" CommandParameter="{Binding}" ToolTip.Tip="复制路径">
                                                        <Path Data="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42z M5.5 8.25c-.96 0-1.75-.79-1.75-1.75s.79-1.75 1.75-1.75 1.75.79 1.75 1.75-.79 1.75-1.75 1.75z" 
                                                              Width="11" Height="11" Stretch="Uniform"/>
                                                    </Button>
                                                    
                                                    <!-- Delete Button -->
                                                    <Button Classes="circle-action danger" Command="{Binding $parent[Window].DataContext.DeleteFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="删除历史">
                                                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                                                              Width="10" Height="10" Stretch="Uniform"/>
                                                    </Button>
                                                    
                                                    <!-- Time Badge -->
                                                    <TextBlock Text="{Binding LastVisited, Converter={StaticResource RelativeTimeConverter}}" 
                                                               FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Bottom Row (Inner Card) -->
                                            <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,2,0,0">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <!-- Left: Folder/File Icon -->
                                                    <Panel Grid.Column="0" Width="22" Height="22" Margin="0,0,8,0" VerticalAlignment="Center">
                                                        <!-- Fallback Icon -->
                                                        <Path Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" 
                                                              Fill="{DynamicResource AccentBrush}" 
                                                              Stretch="Uniform" 
                                                              IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        <!-- Loaded System Icon -->
                                                        <Image Source="{Binding Icon}" 
                                                               Stretch="Uniform" 
                                                               IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                    </Panel>
                                                    
                                                    <!-- Right: Name & Path -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Path}" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Header 2: Apps & Files -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,8" VerticalAlignment="Center">
                        <TextBlock Text="最近打开的应用与文件" Classes="subheader"/>
                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="8,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Apps & Files List wrapped in Border -->
                    <Border Grid.Row="3" Background="{DynamicResource BgCardBrush}" BorderThickness="0" BoxShadow="0 2 10 0 #0A000000" CornerRadius="10" Padding="8">
                        <ListBox ItemsSource="{Binding RecentAppAndFileItems}" 
                                 Background="Transparent" BorderThickness="0" Padding="0"
                                 DoubleTapped="HistoryList_DoubleTapped">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:FolderHistoryItem}">
                                    <Border Classes="outer-card" Background="{DynamicResource BgSecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8,6">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="打开应用/文件" Command="{Binding $parent[Window].DataContext.OpenFolderCommand}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="复制完整路径" Command="{Binding $parent[Window].DataContext.CopyPathCommand}" CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="删除历史记录" Command="{Binding $parent[Window].DataContext.DeleteFolderCommand}" CommandParameter="{Binding}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid RowDefinitions="Auto,Auto">
                                            <!-- Top Row (Header) -->
                                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                                <!-- Left: App Icon & Name -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <Image Source="{Binding Icon}" Width="12" Height="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding AppName}" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                
                                                <!-- Right: Action Buttons & Time -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <!-- Action Buttons (circular, outline) -->
                                                    <!-- Open Button -->
                                                    <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.OpenFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="打开">
                                                        <Path Data="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" 
                                                              Width="11" Height="11" Stretch="Uniform"/>
                                                    </Button>
                                                    
                                                    <!-- Copy Path Button (Tag shape icon) -->
                                                    <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.CopyPathCommand}" CommandParameter="{Binding}" ToolTip.Tip="复制路径">
                                                        <Path Data="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42z M5.5 8.25c-.96 0-1.75-.79-1.75-1.75s.79-1.75 1.75-1.75 1.75.79 1.75 1.75-.79 1.75-1.75 1.75z" 
                                                              Width="11" Height="11" Stretch="Uniform"/>
                                                    </Button>
                                                    
                                                    <!-- Delete Button -->
                                                    <Button Classes="circle-action danger" Command="{Binding $parent[Window].DataContext.DeleteFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="删除历史">
                                                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                                                              Width="10" Height="10" Stretch="Uniform"/>
                                                    </Button>
                                                    
                                                    <!-- Time Badge -->
                                                    <TextBlock Text="{Binding LastVisited, Converter={StaticResource RelativeTimeConverter}}" 
                                                               FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Bottom Row (Inner Card) -->
                                            <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,2,0,0">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <!-- Left: Folder/File Icon -->
                                                    <Panel Grid.Column="0" Width="22" Height="22" Margin="0,0,8,0" VerticalAlignment="Center">
                                                        <!-- Fallback Icon -->
                                                        <Path Data="M6 2c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6H6zm7 7V3.5L18.5 9H13z" 
                                                              Fill="{DynamicResource AccentBrush}" 
                                                              Stretch="Uniform" 
                                                              IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        <!-- Loaded System Icon -->
                                                        <Image Source="{Binding Icon}" 
                                                               Stretch="Uniform" 
                                                               IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                    </Panel>
                                                    
                                                    <!-- Right: Name & Path -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Path}" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>

                <!-- Recent category filter: display one selected category at a time -->
                <Grid IsVisible="{Binding CurrentTab, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Recent}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="7" Margin="0,0,0,8">
                        <ToggleButton Content="文件夹" Classes="filter-tag"
                                      IsChecked="{Binding RecentFilter, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Folders, Mode=OneWay}"
                                      Command="{Binding SwitchRecentFilterCommand}" CommandParameter="Folders"/>
                        <ToggleButton Content="应用" Classes="filter-tag"
                                      IsChecked="{Binding RecentFilter, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Applications, Mode=OneWay}"
                                      Command="{Binding SwitchRecentFilterCommand}" CommandParameter="Applications"/>
                        <ToggleButton Content="文件" Classes="filter-tag"
                                      IsChecked="{Binding RecentFilter, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Files, Mode=OneWay}"
                                      Command="{Binding SwitchRecentFilterCommand}" CommandParameter="Files"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" BoxShadow="0 2 10 0 #0A000000" CornerRadius="10" Padding="8">
                        <ListBox ItemsSource="{Binding CurrentRecentItems}" Background="Transparent" BorderThickness="0" Padding="0" DoubleTapped="HistoryList_DoubleTapped">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:FolderHistoryItem}">
                                    <Border Classes="outer-card" Background="{DynamicResource BgSecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8,6">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="打开" Command="{Binding $parent[Window].DataContext.OpenFolderCommand}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="复制完整路径" Command="{Binding $parent[Window].DataContext.CopyPathCommand}" CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="删除历史记录" Command="{Binding $parent[Window].DataContext.DeleteFolderCommand}" CommandParameter="{Binding}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding LastVisited, Converter={StaticResource RelativeTimeConverter}}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" IsVisible="False" VerticalAlignment="Center" Spacing="2" Margin="9,0">
                                                <TextBlock Text="{Binding AppName}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock IsVisible="False"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.OpenFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="打开">
                                                    <Path Data="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" Width="10" Height="10" Stretch="Uniform"/>
                                                </Button>
                                                <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.PinFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="置顶 / 取消置顶"
                                                        IsVisible="{Binding !IsPinned}">
                                                    <Path Data="M16 9V4h1c.55 0 1-.45 1-1s-.45-1-1-1H7c-.55 0-1 .45-1 1s.45 1 1 1h1v5c0 1.66-1.34 3-3 3v2h5.97v7l1 1 1-1v-7H19v-2c-1.66 0-3-1.34-3-3z" Width="11" Height="11" Stretch="Uniform" RenderTransformOrigin="50%,50%">
                                                        <Path.RenderTransform>
                                                            <TransformGroup>
                                                                <RotateTransform Angle="45"/>
                                                                <TranslateTransform Y="1.3"/>
                                                            </TransformGroup>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Button>
                                                <Button Classes="circle-action pinned" Command="{Binding $parent[Window].DataContext.PinFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="取消置顶"
                                                        IsVisible="{Binding IsPinned}">
                                                    <Path Data="M16 9V4h1c.55 0 1-.45 1-1s-.45-1-1-1H7c-.55 0-1 .45-1 1s.45 1 1 1h1v5c0 1.66-1.34 3-3 3v2h5.97v7l1 1 1-1v-7H19v-2c-1.66 0-3-1.34-3-3z" Width="11" Height="11" Stretch="Uniform">
                                                        <Path.RenderTransform>
                                                            <TranslateTransform X="0.7"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Button>
                                                <Button Classes="circle-action danger" Command="{Binding $parent[Window].DataContext.DeleteFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="删除">
                                                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Width="10" Height="10" Stretch="Uniform"/>
                                                    </Button>
                                            </StackPanel>
                                            <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,5,0,0">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <Image Grid.Column="0" Source="{Binding Icon}" Width="28" Height="28" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" Spacing="1">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Path}" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <TextBox Grid.Row="2" Classes="search" Height="28" Padding="6,4,10,4" Margin="0,10,0,0"
                             Text="{Binding SearchText, Mode=TwoWay}" Watermark="搜索...">
                        <TextBox.InnerLeftContent>
                            <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                                  Fill="{DynamicResource TextSecondaryBrush}" Width="11" Height="11" Stretch="Uniform" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </TextBox.InnerLeftContent>
                    </TextBox>
                </Grid>

                <!-- ================= 3.2 PINNED LIST ================= -->
                <Border IsVisible="{Binding CurrentTab, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Pinned}"
                        Background="{DynamicResource BgCardBrush}" BorderThickness="0" BoxShadow="0 2 10 0 #0A000000" CornerRadius="10" Padding="8">
                    <ListBox ItemsSource="{Binding PinnedItems}" 
                             Background="Transparent" BorderThickness="0" Padding="0"
                             DoubleTapped="HistoryList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:FolderHistoryItem}">
                                <Border Classes="outer-card" Background="{DynamicResource BgSecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8,6">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="打开文件夹" Command="{Binding $parent[Window].DataContext.OpenFolderCommand}" CommandParameter="{Binding}"/>
                                            <MenuItem Header="复制完整路径" Command="{Binding $parent[Window].DataContext.CopyPathCommand}" CommandParameter="{Binding}"/>
                                            <Separator/>
                                            <MenuItem Header="取消置顶" Command="{Binding $parent[Window].DataContext.PinFolderCommand}" CommandParameter="{Binding}"/>
                                            <MenuItem Header="删除历史记录" Command="{Binding $parent[Window].DataContext.DeleteFolderCommand}" CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid RowDefinitions="Auto,Auto">
                                        <!-- Top Row (Header) -->
                                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                            <!-- Left: App Icon & Name -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Image Source="{Binding Icon}" Width="12" Height="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding AppName}" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Right: Action Buttons & Time -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <!-- Action Buttons (circular, outline) -->
                                                <!-- Open Button -->
                                                <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.OpenFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="打开">
                                                    <Path Data="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" 
                                                          Width="11" Height="11" Stretch="Uniform"/>
                                                </Button>
                                                
                                                <!-- Pin Button (Pinned State) -->
                                                <Button Classes="circle-action pinned" Command="{Binding $parent[Window].DataContext.PinFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="取消置顶">
                                                    <Path Data="M16 9V4h1c.55 0 1-.45 1-1s-.45-1-1-1H7c-.55 0-1 .45-1 1s.45 1 1 1h1v5c0 1.66-1.34 3-3 3v2h5.97v7l1 1 1-1v-7H19v-2c-1.66 0-3-1.34-3-3z" 
                                                          Width="11" Height="11" Stretch="Uniform"
                                                          RenderTransformOrigin="50%,50%">
                                                        <Path.RenderTransform>
                                                            <TranslateTransform Y="1"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Button>
                                                
                                                <!-- Copy Path Button (Tag shape icon) -->
                                                <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.CopyPathCommand}" CommandParameter="{Binding}" ToolTip.Tip="复制路径">
                                                    <Path Data="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42z M5.5 8.25c-.96 0-1.75-.79-1.75-1.75s.79-1.75 1.75-1.75 1.75.79 1.75 1.75-.79 1.75-1.75 1.75z" 
                                                          Width="11" Height="11" Stretch="Uniform"/>
                                                </Button>
                                                
                                                <!-- Delete Button -->
                                                <Button Classes="circle-action danger" Command="{Binding $parent[Window].DataContext.DeleteFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="删除历史">
                                                    <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                                                          Width="10" Height="10" Stretch="Uniform"/>
                                                </Button>
                                                
                                                <!-- Time Badge -->
                                                <TextBlock Text="{Binding LastVisited, Converter={StaticResource RelativeTimeConverter}}" 
                                                           FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <!-- Bottom Row (Inner Card) -->
                                        <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,2,0,0">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <!-- Left: Folder/File Icon -->
                                                <Panel Grid.Column="0" Width="22" Height="22" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <!-- Fallback Icon -->
                                                    <Path Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" 
                                                          Fill="{DynamicResource AccentBrush}" 
                                                          Stretch="Uniform" 
                                                          IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                    <!-- Loaded System Icon -->
                                                    <Image Source="{Binding Icon}" 
                                                           Stretch="Uniform" 
                                                           IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                </Panel>
                                                
                                                <!-- Right: Name & Path -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Path}" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- ================= 3.3 STATS LIST ================= -->
                <Border IsVisible="{Binding CurrentTab, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Stats}"
                        Background="{DynamicResource BgCardBrush}" BorderThickness="0" BoxShadow="0 2 10 0 #0A000000" CornerRadius="10" Padding="8">
                    <ListBox ItemsSource="{Binding StatsItems}" 
                             Background="Transparent" BorderThickness="0" Padding="0"
                             DoubleTapped="HistoryList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:FolderHistoryItem}">
                                <Border Classes="outer-card" Background="{DynamicResource BgSecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8,6">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="打开文件夹" Command="{Binding $parent[Window].DataContext.OpenFolderCommand}" CommandParameter="{Binding}"/>
                                            <MenuItem Header="复制完整路径" Command="{Binding $parent[Window].DataContext.CopyPathCommand}" CommandParameter="{Binding}"/>
                                            <Separator/>
                                            <MenuItem Header="删除历史记录" Command="{Binding $parent[Window].DataContext.DeleteFolderCommand}" CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid RowDefinitions="Auto,Auto">
                                        <!-- Top Row (Header) -->
                                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                            <!-- Left: App Icon & Name -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Image Source="{Binding Icon}" Width="12" Height="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding AppName}" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Right: Action Buttons & Stats Count -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <!-- Action Buttons (circular, outline) -->
                                                <!-- Open Button -->
                                                <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.OpenFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="打开">
                                                    <Path Data="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" 
                                                          Width="11" Height="11" Stretch="Uniform"/>
                                                </Button>
                                                
                                                <!-- Copy Path Button (Tag shape icon) -->
                                                <Button Classes="circle-action" Command="{Binding $parent[Window].DataContext.CopyPathCommand}" CommandParameter="{Binding}" ToolTip.Tip="复制路径">
                                                    <Path Data="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42z M5.5 8.25c-.96 0-1.75-.79-1.75-1.75s.79-1.75 1.75-1.75 1.75.79 1.75 1.75-.79 1.75-1.75 1.75z" 
                                                          Width="11" Height="11" Stretch="Uniform"/>
                                                </Button>
                                                
                                                <!-- Delete Button -->
                                                <Button Classes="circle-action danger" Command="{Binding $parent[Window].DataContext.DeleteFolderCommand}" CommandParameter="{Binding}" ToolTip.Tip="删除历史">
                                                    <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                                                          Width="10" Height="10" Stretch="Uniform"/>
                                                </Button>
                                                
                                                <!-- Stats Count -->
                                                <StackPanel Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="访问 " FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding VisitCount}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                                    <TextBlock Text=" 次" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <!-- Bottom Row (Inner Card) -->
                                        <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,2,0,0">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <!-- Left: Folder/File Icon -->
                                                <Panel Grid.Column="0" Width="22" Height="22" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <!-- Fallback Icon -->
                                                    <Path Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" 
                                                          Fill="{DynamicResource AccentBrush}" 
                                                          Stretch="Uniform" 
                                                          IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                    <!-- Loaded System Icon -->
                                                    <Image Source="{Binding Icon}" 
                                                           Stretch="Uniform" 
                                                           IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                </Panel>
                                                
                                                <!-- Right: Name & Path -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Path}" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- ================= 3.4 SETTINGS PAGE ================= -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                               IsVisible="{Binding CurrentTab, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Settings}">
                    <StackPanel Margin="4,4,4,8" Spacing="12">
                        <TextBlock Text="数据维护与设置" FontSize="14" FontWeight="Bold" Margin="4,4,0,8"/>

                        <!-- 常规设置卡片 -->
                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="常规设置" Classes="cardTitle" />

                                <!-- 窗口置顶 -->
                                <Grid Classes="fieldRow" ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="窗口置顶模式" Classes="fieldLabel" />
                                        <TextBlock Text="保持窗口最前，且失去焦点时软件不会隐藏或退出。" Classes="fieldHint" />
                                    </StackPanel>
                                    <Border Grid.Column="1" VerticalAlignment="Center" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="2" ClipToBounds="True">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton GroupName="GrpTopmost" Classes="segmented" Content="关闭" IsChecked="{Binding IsTopmost, Converter={StaticResource InverseBooleanConverter}, Mode=TwoWay}" />
                                            <Rectangle Classes="segmentedDivider" />
                                            <RadioButton GroupName="GrpTopmost" Classes="segmented" Content="开启" IsChecked="{Binding IsTopmost, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Border Classes="softDivider" />

                                <!-- 后台监测 -->
                                <Grid Classes="fieldRow" ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="后台持续运行监测" Classes="fieldLabel" />
                                        <TextBlock Text="在后台记录您启动的软件和最近打开的文件历史。" Classes="fieldHint" />
                                    </StackPanel>
                                    <Border Grid.Column="1" VerticalAlignment="Center" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="2" ClipToBounds="True">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton GroupName="GrpBgMonitor" Classes="segmented" Content="关闭" IsChecked="{Binding IsBackgroundMonitorEnabled, Converter={StaticResource InverseBooleanConverter}, Mode=TwoWay}" />
                                            <Rectangle Classes="segmentedDivider" />
                                            <RadioButton GroupName="GrpBgMonitor" Classes="segmented" Content="开启" IsChecked="{Binding IsBackgroundMonitorEnabled, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 外观设置卡片 -->
                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="外观设置" Classes="cardTitle" />

                                <!-- 主题颜色模式 -->
                                <Grid Classes="fieldRow" ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="主题颜色模式" Classes="fieldLabel" />
                                        <TextBlock Text="切换应用亮暗色界面风格或跟随系统。" Classes="fieldHint" />
                                    </StackPanel>
                                    <Border Grid.Column="1" VerticalAlignment="Center" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="2" ClipToBounds="True">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton GroupName="ThemeGroup" Classes="segmented" Content="跟随系统" IsChecked="{Binding IsSystemTheme, Mode=TwoWay}" />
                                            <Rectangle Classes="segmentedDivider" />
                                            <RadioButton GroupName="ThemeGroup" Classes="segmented" Content="浅色" IsChecked="{Binding IsLightTheme, Mode=TwoWay}" />
                                            <Rectangle Classes="segmentedDivider" />
                                            <RadioButton GroupName="ThemeGroup" Classes="segmented" Content="暗色" IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 数据维护卡片 -->
                        <Border Classes="card">
                            <StackPanel Spacing="12">
                                <TextBlock Text="数据维护" Classes="cardTitle" />
                                
                                <Button Click="OpenDataFolderButton_Click" Classes="modern" Content="打开历史数据文件夹" Height="34" HorizontalAlignment="Stretch" FontSize="11" FontWeight="SemiBold"/>
                                
                                <Button Command="{Binding ClearAllCommand}" Classes="danger" Height="34" HorizontalAlignment="Stretch">
                                    <TextBlock Text="清空所有记录" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource DangerBrush}"/>
                                </Button>

                                <Button Click="ExitApplicationButton_Click" Classes="danger" Height="34" HorizontalAlignment="Stretch">
                                    <TextBlock Text="退出程序" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource DangerBrush}"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 关于软件卡片 -->
                        <Border Classes="card" Margin="0,0,0,12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="关于软件" Classes="cardTitle" />
                                
                                <!-- 作者 -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,2">
                                    <TextBlock Text="作者" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="北京林或西" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                                <Border Classes="softDivider" />
                                
                                <!-- 开发维护 -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,2">
                                    <TextBlock Text="开发维护" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Click="QQGroupButton_Click" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" ToolTip.Tip="点击加入QQ群: 453478357">
                                        <TextBlock Text="Quicker地球村(QQ群: 453478357)" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource AccentBrush}" TextDecorations="Underline"/>
                                    </Button>
                                </Grid>
                                <Border Classes="softDivider" />
                                
                                <!-- 开源协议 -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,2">
                                    <TextBlock Text="开源协议" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="本软件开源免费" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                                <Border Classes="softDivider" />
                                
                                <!-- 技术架构 -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,2">
                                    <TextBlock Text="技术架构" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="基于 .NET 8 与 Avalonia 11 构建&#x0a;(启用 NativeAOT 极致性能优化)" FontSize="10.5" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right" TextAlignment="Right" LineHeight="15"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ================= 4. DIALOG OVERLAY ================= -->
            <Grid Grid.Row="0" Grid.RowSpan="4" IsVisible="{Binding IsDialogOpen}" Background="{DynamicResource DialogOverlayBrush}" ZIndex="1000">
                <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Width="260" Padding="16" VerticalAlignment="Center" HorizontalAlignment="Center" BoxShadow="0 4 20 0 #2A000000">
                    <StackPanel>
                        <!-- Title -->
                        <TextBlock Text="{Binding DialogTitle}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                        
                        <!-- Content Text -->
                        <TextBlock Text="{Binding DialogText}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16" HorizontalAlignment="Center" TextAlignment="Center"/>
                        
                        <!-- Action Buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- If Confirmation needed -->
                            <Button Grid.Column="0" Command="{Binding ConfirmDialogCommand}" Classes="modern" Content="确定" IsVisible="{Binding IsDialogConfirmVisible}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Command="{Binding CancelDialogCommand}" Classes="modern" Content="取消" IsVisible="{Binding IsDialogConfirmVisible}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0"/>
                            
                            <!-- If Alert only -->
                            <Button Grid.ColumnSpan="2" Command="{Binding ConfirmDialogCommand}" Classes="modern" Content="确定" IsVisible="{Binding !IsDialogConfirmVisible}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ================= RESIZE BORDERS & CORNERS ================= -->
            <Border Grid.Row="0" Grid.RowSpan="4" Width="5" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWestEast" Tag="West" PointerPressed="Resize_PointerPressed"/>
            <Border Grid.Row="0" Grid.RowSpan="4" Width="5" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWestEast" Tag="East" PointerPressed="Resize_PointerPressed"/>
            <Border Grid.Row="0" Grid.RowSpan="4" Height="5" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNorthSouth" Tag="North" PointerPressed="Resize_PointerPressed"/>
            <Border Grid.Row="0" Grid.RowSpan="4" Height="5" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNorthSouth" Tag="South" PointerPressed="Resize_PointerPressed"/>

            <Border Grid.Row="0" Grid.RowSpan="4" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" Cursor="TopLeftCorner" Tag="NorthWest" PointerPressed="Resize_PointerPressed"/>
            <Border Grid.Row="0" Grid.RowSpan="4" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" Cursor="TopRightCorner" Tag="NorthEast" PointerPressed="Resize_PointerPressed"/>
            <Border Grid.Row="0" Grid.RowSpan="4" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomLeftCorner" Tag="SouthWest" PointerPressed="Resize_PointerPressed"/>
            <Border Grid.Row="0" Grid.RowSpan="4" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomRightCorner" Tag="SouthEast" PointerPressed="Resize_PointerPressed"/>
        </Grid>
    </Border>
</Window>
